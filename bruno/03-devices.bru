meta {
  name: List devices
  type: http
  seq: 3
}

post {
  url: https://smarthome.wattselectronics.com/api/v0.1/human/smarthome/read/
  body: formUrlEncoded
  auth: none
}

headers {
  Authorization: Bearer {{accessToken}}
}

body:form-urlencoded {
  token: true
  smarthome_id: {{smartHomeId}}
  lang: nl_NL
}
